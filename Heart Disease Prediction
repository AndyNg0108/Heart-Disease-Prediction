   },
   "source": [
    "Outliers in clinical data ussually mean one of three things: (1) genuine extreme cases, (2) data entry errors, or (3) rare pathological states. We use IQR capping - not removal - to preserve all 630K patients while preventing extreme values from domating model splits. We use a conservative factor (3.0xIQR) to advoid clipping genuine clinical extremes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "7e718f6c",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-03-09T05:04:12.597749Z",
     "iopub.status.busy": "2026-03-09T05:04:12.596832Z",
     "iopub.status.idle": "2026-03-09T05:04:13.535840Z",
     "shell.execute_reply": "2026-03-09T05:04:13.534550Z"
    },
    "papermill": {
     "duration": 0.967711,
     "end_time": "2026-03-09T05:04:13.537967",
     "exception": false,
     "start_time": "2026-03-09T05:04:12.570256",
     "status": "completed"
    },
    "tags": []
   },
   "outputs": [
    {
     "data": {
      "image/png": "\n",
      "text/plain": [
       "<Figure size 1600x1200 with 6 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "def iqr_cap(series, factor=3.0):\n",
    "    \"\"\"Cap values at Q1 - factor*IQR and Q3 + factor*IQR\"\"\"\n",
    "    Q1, Q3 = series.quantile(0.25), series.quantile(0.75)\n",
    "    IQR = Q3 - Q1 \n",
    "    lo, hi = Q1 - factor * IQR, Q3 + factor * IQR\n",
    "    return series.clip(lo, hi), lo, hi\n",
    "\n",
    "outlier_cols = ['BP', 'Cholesterol', 'ST depression']\n",
    "fig, axes = plt.subplots(len(outlier_cols), 2, figsize=(16, 4*len(outlier_cols)))\n",
    "\n",
    "for i, col in enumerate(outlier_cols):\n",
    "    original = train_fe[col].copy()\n",
    "    capped, lo, hi = iqr_cap(train_fe[col])\n",
    "    train_fe[col] = capped\n",
    "    test_fe[col] = test_fe[col].clip(lo, hi)\n",
    "    axes[i, 0].boxplot(original, patch_artist=True, boxprops=dict(facecolor=COLORS['Presence'], alpha=0.5),\n",
    "                      medianprops=dict(color='black', linewidth=2))\n",
    "    axes[i, 0].set_title(f'{col} - Before Capping', fontweight='bold')\n",
    "    axes[i, 1].boxplot(capped, patch_artist=True, boxprops=dict(facecolor='#2ecc71', alpha=0.5),\n",
    "                      medianprops=dict(color='black', linewidth=2))\n",
    "    axes[i, 1].set_title(f'{col} -  After IQR Capping (factor = 3)', fontweight='bold')\n",
    "\n",
    "plt.suptitle('Outlier Treatment - Before vs. After', fontsize=16, fontweight='bold', y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n"
   ]
