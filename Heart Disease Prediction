    "for df in [train_fe, test_fe]:\n",
    "    #1. Age risk bucket - standard cardiovascular risk threshholds\n",
    "    df['age_risk'] = pd.cut(df['Age'], bins=[0, 40, 55, 65, 120], labels=[0, 1, 2,3]).astype(int)\n",
    "    #2. BP x Cholesterol interaction - combined cardiovascular burden score \n",
    "    df['bp_chol_interaction'] = df['BP'] * df['Cholesterol'] / 10000\n",
    "    #3. HR reserve ratio - achieved HR as % of age-predicted max (220-Age)\n",
    "    # Low ratio = heart cannot respond to exercise demand = poor cardiac function\n",
    "    df['hr_reserve_ratio'] = df['Max HR'] / (220 - df['Age'])\n",
    "    #4. Exercise stress score - ST depression normalized by HR reserve\n",
    "    # High ST depression + low HR reserve = serve ischema under exercise\n",
    "    df['stress_score'] = df['ST depression'] / (df['hr_reserve_ratio'] + 1e-6)\n",
    "    #5. Silent ischema flag - asymptomatic chest pain with exercise-induced angina\n",
    "    #This combination is a red flag: no symptioms at rest but clear ischemia under load\n",
    "    df['silent_ischemia_flag'] = ((df['Chest pain type'] == 4)&(df['Exercise angina'] == 1)).astype(int)\n",
    "\n",
    "new_features = ['age_risk', 'bp_chol_interaction', 'hr_reserve_ratio', 'stress_score', 'silent_ischemia_flag']\n",
    "\n",
    "print(\"New feature created:\")\n",
    "display(train_fe[new_features].describe().round(3))"
